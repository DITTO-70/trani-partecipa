# ── Copia questo file in .env e compila i valori ──────────────────────────────

# Stringa di connessione al database Supabase
# La trovi in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Porta del server Express (Vercel/Railway la imposta automaticamente)
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Origin/i permessi per CORS (separati da virgola se più di uno)
CORS_ORIGIN=http://localhost:3000,http://localhost:5500,https://trani-partecipa.vercel.app

# Credenziali admin (NON inserire mai questi valori nel codice frontend)
ADMIN_USER=inserisci_username_admin
ADMIN_PASS=inserisci_password_sicura
