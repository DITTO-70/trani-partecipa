# ── Copia questo file in .env e compila i valori ──────────────────────────────

# Stringa di connessione al database Supabase (o altro PostgreSQL)
# La trovi in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Porta del server Express (Railway la imposta automaticamente)
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Origin/i permessi per CORS (separati da virgola se più di uno)
# In development puoi usare * — in produzione specifica l'URL del frontend
CORS_ORIGIN=http://localhost:5500,https://trani-partecipa.vercel.app
